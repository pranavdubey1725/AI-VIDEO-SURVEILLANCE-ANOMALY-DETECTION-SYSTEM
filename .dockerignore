# Version control
.git/
.gitignore

# Python bytecode
__pycache__/
*.py[cod]
*.pyo

# Virtual environment
venv/
env/
.venv/

# Dataset — too large to ship in image (11.8 GB)
data/raw/

# Pre-computed features — regenerated by extract_features.py
data/features/

# Clip CSVs — regenerated by build_splits.py (421 MB total)
data/splits/train.csv
data/splits/val.csv
data/splits/test.csv

# Intermediate epoch checkpoints — only best_model.pt is needed
checkpoints/epoch_*.pt

# Logs
*.log
checkpoints/training.log
checkpoints/training2.log
checkpoints/training3.log

# YOLOv8 weights — auto-downloaded by ultralytics on first run
yolov8n.pt

# Test/CI artifacts
.pytest_cache/
.coverage
htmlcov/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Notebooks
notebooks/
.ipynb_checkpoints/
*.ipynb

# Scratch files
new.md
